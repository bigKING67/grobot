#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  TARGET="$(readlink "$SOURCE")"
  if [[ "$TARGET" != /* ]]; then
    SOURCE="$SCRIPT_DIR/$TARGET"
  else
    SOURCE="$TARGET"
  fi
done

SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
PACKAGE_ROOT="$(cd "$SCRIPT_DIR/../../.." && pwd)"

detect_platform_key() {
  local os arch
  os="$(uname -s 2>/dev/null || echo unknown)"
  arch="$(uname -m 2>/dev/null || echo unknown)"
  case "${os}:${arch}" in
    Darwin:arm64) echo "darwin-arm64" ;;
    Darwin:x86_64) echo "darwin-x64" ;;
    Linux:x86_64) echo "linux-x64" ;;
    Linux:aarch64|Linux:arm64) echo "linux-arm64" ;;
    *) echo "" ;;
  esac
}

detect_core_package() {
  local platform_key="$1"
  case "$platform_key" in
    darwin-arm64) echo "@grobot/core-darwin-arm64" ;;
    darwin-x64) echo "@grobot/core-darwin-x64" ;;
    linux-x64) echo "@grobot/core-linux-x64" ;;
    linux-arm64) echo "@grobot/core-linux-arm64" ;;
    *) echo "" ;;
  esac
}

GROBOT_HOME_DIR="${GROBOT_HOME:-${HOME}/.grobot}"
PLATFORM_KEY="$(detect_platform_key)"
CORE_PACKAGE="$(detect_core_package "$PLATFORM_KEY")"

# 1) Explicit binary override.
if [ -n "${GROBOT_CORE_BIN:-}" ]; then
  if [ -x "${GROBOT_CORE_BIN}" ]; then
    exec "${GROBOT_CORE_BIN}" "$@"
  fi
  echo "warning: GROBOT_CORE_BIN is set but not executable: ${GROBOT_CORE_BIN}" >&2
fi

# 2) User-level installed core via ~/.grobot/core/current/grobot-core.
CANDIDATE="${GROBOT_HOME_DIR}/core/current/grobot-core"
if [ -x "$CANDIDATE" ]; then
  exec "$CANDIDATE" "$@"
fi

# 3) User-level platform slot: ~/.grobot/core/<platform>/grobot-core.
if [ -n "$PLATFORM_KEY" ]; then
  CANDIDATE="${GROBOT_HOME_DIR}/core/${PLATFORM_KEY}/grobot-core"
  if [ -x "$CANDIDATE" ]; then
    exec "$CANDIDATE" "$@"
  fi
fi

# 4) Node-installed platform package.
if [ -n "$CORE_PACKAGE" ]; then
  CANDIDATE="${PACKAGE_ROOT}/node_modules/${CORE_PACKAGE}/bin/grobot-core"
  if [ -x "$CANDIDATE" ]; then
    exec "$CANDIDATE" "$@"
  fi
fi

# 5) Source checkout fallback.
#    Default to TS dev CLI. Python fallback is opt-in via legacy flag/env.
DEV_TS_CLI_RUNNER="${PACKAGE_ROOT}/scripts/run-ts-dev-cli.sh"
DEV_CLI="${PACKAGE_ROOT}/gateway/grobot_cli.py"
FORWARD_ARGS=()
LEGACY_PYTHON_ENABLED=0
TS_DEV_FLAG_SEEN=0
FORCE_PYTHON_EXECUTION=0
PREV_ARG=""
for ARG in "$@"; do
  if [ -n "$PREV_ARG" ]; then
    if [ "$PREV_ARG" = "--gateway-impl" ] || [ "$PREV_ARG" = "--runtime-impl" ]; then
      if [ "$ARG" = "python" ]; then
        FORCE_PYTHON_EXECUTION=1
      fi
      FORWARD_ARGS+=("$ARG")
      PREV_ARG=""
      continue
    fi
    PREV_ARG=""
  fi
  case "$ARG" in
    --legacy-python-cli)
      LEGACY_PYTHON_ENABLED=1
      ;;
    --legacy-python-cli=*)
      LEGACY_VALUE="${ARG#*=}"
      LEGACY_VALUE_LOWER="$(printf '%s' "$LEGACY_VALUE" | tr '[:upper:]' '[:lower:]')"
      case "$LEGACY_VALUE_LOWER" in
        1|true|yes|on) LEGACY_PYTHON_ENABLED=1 ;;
      esac
      ;;
    --ts-dev-cli|--ts-dev-cli=*)
      TS_DEV_FLAG_SEEN=1
      ;;
    --gateway-impl|--runtime-impl)
      PREV_ARG="$ARG"
      FORWARD_ARGS+=("$ARG")
      ;;
    --gateway-impl=python|--runtime-impl=python)
      FORCE_PYTHON_EXECUTION=1
      FORWARD_ARGS+=("$ARG")
      ;;
    *)
      FORWARD_ARGS+=("$ARG")
      ;;
  esac
done

LEGACY_ENV_VALUE_LOWER="$(printf '%s' "${GROBOT_LEGACY_PYTHON:-}" | tr '[:upper:]' '[:lower:]')"
case "$LEGACY_ENV_VALUE_LOWER" in
  1|true|yes|on) LEGACY_PYTHON_ENABLED=1 ;;
esac

if [ "$TS_DEV_FLAG_SEEN" -eq 1 ]; then
  echo "warning: --ts-dev-cli is deprecated and can be removed." >&2
fi

if [ "$FORCE_PYTHON_EXECUTION" -eq 1 ] && [ -f "$DEV_CLI" ]; then
  echo "warning: using legacy python cli because execution plane explicitly requests python." >&2
  exec python3 "$DEV_CLI" "${FORWARD_ARGS[@]}"
fi

if [ "$LEGACY_PYTHON_ENABLED" -eq 1 ] && [ -f "$DEV_CLI" ]; then
  echo "warning: using legacy python cli fallback (explicitly enabled)." >&2
  exec python3 "$DEV_CLI" "${FORWARD_ARGS[@]}"
fi

TS_DEV_CLI_EXIT_CODE=86
TS_DEV_CLI_AVAILABLE=0
if [ -x "$DEV_TS_CLI_RUNNER" ]; then
  TS_DEV_CLI_AVAILABLE=1
  set +e
  "$DEV_TS_CLI_RUNNER" "${FORWARD_ARGS[@]}"
  TS_DEV_CLI_EXIT_CODE=$?
  set -e
  if [ "$TS_DEV_CLI_EXIT_CODE" -eq 0 ]; then
    exit 0
  fi
  if [ "$TS_DEV_CLI_EXIT_CODE" -ne 2 ] && [ "$TS_DEV_CLI_EXIT_CODE" -ne 3 ] && [ "$TS_DEV_CLI_EXIT_CODE" -ne 86 ]; then
    exit "$TS_DEV_CLI_EXIT_CODE"
  fi
fi

if [ "$TS_DEV_CLI_AVAILABLE" -eq 1 ]; then
  if [ "$TS_DEV_CLI_EXIT_CODE" -eq 86 ]; then
    echo "error: ts-dev-cli is unavailable in this source checkout." >&2
  elif [ "$TS_DEV_CLI_EXIT_CODE" -eq 2 ] || [ "$TS_DEV_CLI_EXIT_CODE" -eq 3 ]; then
    echo "error: command is not available in ts-dev-cli yet." >&2
  fi
  echo "hint: use --legacy-python-cli or GROBOT_LEGACY_PYTHON=1 during transition." >&2
  exit "$TS_DEV_CLI_EXIT_CODE"
fi

echo "grobot core not found for this platform." >&2
echo "platform key: ${PLATFORM_KEY:-unsupported}" >&2
echo "platform package: ${CORE_PACKAGE:-unsupported}" >&2
echo "searched:" >&2
echo "  - GROBOT_CORE_BIN=${GROBOT_CORE_BIN:-<unset>}" >&2
echo "  - ${GROBOT_HOME_DIR}/core/current/grobot-core" >&2
echo "  - ${GROBOT_HOME_DIR}/core/${PLATFORM_KEY:-<platform>}/grobot-core" >&2
echo "  - ${PACKAGE_ROOT}/node_modules/${CORE_PACKAGE:-@grobot/core-<platform>}/bin/grobot-core" >&2
echo "hint: install core to ~/.grobot/core/current or set GROBOT_CORE_BIN." >&2
echo "hint: source-checkout compatibility fallback requires --legacy-python-cli (or GROBOT_LEGACY_PYTHON=1)." >&2
exit 1
