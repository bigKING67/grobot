{
  "schema": "trace_pipeline_policy",
  "schema_version": 2,
  "profile": "dev",
  "sessions_dir": "../../.grobot/sessions",
  "trace_cases_output": "data/cases.trace.jsonl",
  "trace_runs_output": "data/runs.trace_baseline.jsonl",
  "variant": "trace_baseline",
  "holdout_ratio": 0.2,
  "seed": 42,
  "max_cases": 30,
  "min_chars": 1,
  "clean_cases_output": "data/cases.trace.cleaned.jsonl",
  "clean_runs_output": "data/runs.trace.cleaned.jsonl",
  "clean_report_output": "data/trace_clean_report.json",
  "min_prompt_chars": 4,
  "min_response_chars": 2,
  "max_exact_duplicates_per_prompt": 2,
  "similarity_threshold": 0.9,
  "max_near_duplicates_per_anchor": 1,
  "min_cases_per_split": 0,
  "min_clean_cases": 0,
  "fail_on_low_sample": false,
  "min_clean_cases_by_split": {},
  "fail_on_split_underflow": false
}
