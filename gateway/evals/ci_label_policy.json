{
  "schema": "ci_label_policy",
  "schema_version": 1,
  "safe_label_pattern": "^ci\\/[a-z0-9][a-z0-9/_-]{0,49}$",
  "comment_marker": "<!-- harness-gate-summary -->",
  "comment_trigger": {
    "overall_states": [
      "fail"
    ],
    "trend_severities": [
      "warn",
      "error"
    ]
  },
  "comment_template": {
    "title": "### Harness Gate Signal",
    "fields": [
      {
        "key": "overall",
        "label": "overall",
        "format": "code"
      },
      {
        "key": "trend_tag",
        "label": "trend_tag",
        "format": "code"
      },
      {
        "key": "trend_severity",
        "label": "trend_severity",
        "format": "code"
      },
      {
        "key": "policy_drift",
        "label": "policy_drift",
        "format": "code"
      },
      {
        "key": "auto_loop_state",
        "label": "auto_loop_state",
        "format": "code"
      },
      {
        "key": "auto_loop_selected_variant",
        "label": "auto_loop_selected_variant",
        "format": "code"
      },
      {
        "key": "auto_loop_selected_proposal",
        "label": "auto_loop_selected_proposal",
        "format": "code"
      },
      {
        "key": "auto_loop_circuit_breaker",
        "label": "auto_loop_circuit_breaker",
        "format": "code"
      },
      {
        "key": "owner",
        "label": "owner",
        "format": "code"
      },
      {
        "key": "action",
        "label": "action",
        "format": "text"
      },
      {
        "key": "suggested_labels",
        "label": "suggested_labels",
        "format": "code"
      }
    ]
  },
  "policy_drift": {
    "label_prefix": "ci/policy-drift-",
    "worsening_alert_threshold": 2,
    "worsening_label": "ci/policy-drift-worsening",
    "comment_trigger_severities": [
      "high",
      "medium"
    ],
    "action_hints": {
      "high": "Policy schema mismatch detected, sync ci_label_policy immediately before merge.",
      "medium": "Policy fields missing, sync policy template before merge.",
      "low": "Policy has unknown fields, verify compatibility and clean up drift.",
      "none": "n/a"
    }
  },
  "managed_label_prefixes": [
    "ci/harness-",
    "ci/severity-",
    "ci/owner-",
    "ci/action-",
    "ci/auto-loop-",
    "ci/trend-",
    "ci/policy-drift-",
    "ci/policy-drift-worsening"
  ],
  "default_color": "6a737d",
  "default_description": "Generated by harness gate automation",
  "label_rules": [
    {
      "prefix": "ci/harness-pass",
      "color": "0e8a16",
      "description": "Harness gate overall state"
    },
    {
      "prefix": "ci/harness-fail",
      "color": "b60205",
      "description": "Harness gate overall state"
    },
    {
      "prefix": "ci/severity-error",
      "color": "b60205",
      "description": "Harness trend decision severity"
    },
    {
      "prefix": "ci/severity-warn",
      "color": "fbca04",
      "description": "Harness trend decision severity"
    },
    {
      "prefix": "ci/severity-info",
      "color": "0e8a16",
      "description": "Harness trend decision severity"
    },
    {
      "prefix": "ci/action-required",
      "color": "b60205",
      "description": "Suggested CI remediation action"
    },
    {
      "prefix": "ci/action-review",
      "color": "fbca04",
      "description": "Suggested CI remediation action"
    },
    {
      "prefix": "ci/auto-loop-ready",
      "color": "0e8a16",
      "description": "Auto-loop has selected candidate ready for manual promotion"
    },
    {
      "prefix": "ci/auto-loop-no-selection",
      "color": "fbca04",
      "description": "Auto-loop completed without selected candidate"
    },
    {
      "prefix": "ci/auto-loop-circuit-breaker",
      "color": "b60205",
      "description": "Auto-loop triggered circuit breaker"
    },
    {
      "prefix": "ci/auto-loop-missing",
      "color": "5319e7",
      "description": "Auto-loop report missing or unavailable"
    },
    {
      "prefix": "ci/owner-",
      "color": "1d76db",
      "description": "Suggested owner for CI follow-up"
    },
    {
      "prefix": "ci/trend-",
      "color": "5319e7",
      "description": "Skill-router trend decision tag"
    },
    {
      "prefix": "ci/policy-drift-high",
      "color": "b60205",
      "description": "CI label policy runtime drift severity"
    },
    {
      "prefix": "ci/policy-drift-medium",
      "color": "fbca04",
      "description": "CI label policy runtime drift severity"
    },
    {
      "prefix": "ci/policy-drift-low",
      "color": "5319e7",
      "description": "CI label policy runtime drift severity"
    },
    {
      "prefix": "ci/policy-drift-none",
      "color": "0e8a16",
      "description": "CI label policy runtime drift severity"
    },
    {
      "prefix": "ci/policy-drift-worsening",
      "color": "d93f0b",
      "description": "CI label policy drift worsening alert"
    }
  ]
}
