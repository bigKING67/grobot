{
  "schema": "trace_pipeline_policy",
  "schema_version": 2,
  "profile": "ci",
  "sessions_dir": "fixtures/sessions.ci",
  "trace_cases_output": "/tmp/grobot-cases.trace.ci.jsonl",
  "trace_runs_output": "/tmp/grobot-runs.trace.ci.jsonl",
  "variant": "trace_baseline",
  "holdout_ratio": 0.2,
  "seed": 42,
  "max_cases": 20,
  "min_chars": 1,
  "clean_cases_output": "/tmp/grobot-cases.trace.cleaned.ci.jsonl",
