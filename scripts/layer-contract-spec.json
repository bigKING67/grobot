{
  "schema": "layer_contract_v1",
  "layers": [
    {
      "name": "runtime-model",
      "path": "runtime/src/models",
      "requiredDirs": ["providers"]
    },
    {
      "name": "runtime-tools",
      "path": "runtime/src/tools",
      "requiredDirs": [
        "core",
        "dispatcher",
        "list",
        "glob",
        "search",
        "read",
        "write",
        "edit",
        "bash",
        "mcp",
        "semantic",
        "providers"
      ],
      "entrypointIncludeChecks": [
        {
          "path": "runtime/src/tools/tools.rs",
          "includeRequiredDirs": true,
          "allowedExtraIncludeDirs": ["file_snapshot", "file_mutation"],
          "allowedExtraIncludeFiles": ["recovery.rs", "text_format.rs", "tests.rs"]
        }
      ]
    },
    {
      "name": "runtime-extensions",
      "path": "runtime/src/extensions",
      "requiredDirs": []
    },
    {
      "name": "runtime-orchestration",
      "path": "runtime/src/orchestration",
      "requiredDirs": []
    },
    {
      "name": "runtime-governance",
      "path": "runtime/src/governance",
      "requiredDirs": []
    },
    {
      "name": "gateway-model",
      "path": "gateway/src/models",
      "requiredDirs": ["context"]
    },
    {
      "name": "gateway-tools",
      "path": "gateway/src/tools",
      "requiredDirs": ["runtime", "state"]
    },
    {
      "name": "gateway-extensions",
      "path": "gateway/src/extensions",
      "requiredDirs": ["contracts"]
    },
    {
      "name": "gateway-orchestration",
      "path": "gateway/src/orchestration",
      "requiredDirs": ["entrypoints", "orchestrator"]
    },
    {
      "name": "gateway-governance",
      "path": "gateway/src/governance",
      "requiredDirs": ["evals"]
    }
  ],
  "docs": [
    {
      "path": "README.md",
      "mustInclude": [
        "Layer Directory Contract v1",
        "模型层（Model Layer）",
        "治理平面（Governance Plane）"
      ]
    },
    {
      "path": "runtime/README.md",
      "mustInclude": [
        "Layer Directory Contract (Runtime)",
        "新增模块流程",
        "评审检查点"
      ]
    },
    {
      "path": "gateway/README.md",
      "mustInclude": [
        "Layer Directory Contract (Gateway)",
        "边界约束",
        "治理平面"
      ]
    },
    {
      "path": "gateway/evals/README.md",
      "mustInclude": [
        "治理平面目录契约（Gateway）",
        "新增模块流程",
        "评审检查点"
      ]
    }
  ],
  "maxLinesWarnings": [
    {
      "path": "runtime/src/models/model.rs",
      "max": 120
    },
    {
      "path": "runtime/src/tools/tools.rs",
      "max": 120
    },
    {
      "path": "runtime/src/extensions/protocol.rs",
      "max": 120
    },
    {
      "path": "runtime/src/orchestration/orchestrator.rs",
      "max": 120
    },
    {
      "path": "runtime/src/governance/session.rs",
      "max": 80
    }
  ],
  "trackedGeneratedStateWarnings": [
    {
      "name": "grobot-runtime-state",
      "pathPrefixes": [
        ".grobot/context/",
        ".grobot/experience/tenant/",
        ".grobot/memory/context-engine/",
        ".grobot/memory/v1/",
        ".grobot/runtime/",
        ".grobot/session/",
        ".grobot/tmp/",
        ".grobot/wiki/shared/",
        ".grobot/wiki/users/"
      ],
      "allowedBasenames": ["README.md", ".gitkeep"]
    }
  ],
  "legacyPathWarnings": [
    {
      "name": "gateway-dev-cli",
      "pathPrefixes": ["gateway/src/orchestration/entrypoints/dev-cli/"],
      "maxFiles": 0,
      "message": "product CLI source belongs under gateway/src/cli; dev-cli is runner compatibility only"
    },
    {
      "name": "gateway-dev-cli-contract-names",
      "pathPrefixes": [
        "gateway/src/extensions/contracts/dev-cli-",
        "gateway/src/extensions/contracts/dev-cli-ui-renderer-contract/"
      ],
      "maxFiles": 0,
      "message": "CLI/TUI contracts must use cli-* names; dev-cli is runner compatibility only"
    },
    {
      "name": "gateway-start-run-prefix",
      "pathPrefixes": ["gateway/src/cli/start/run-start"],
      "maxFiles": 0,
      "message": "start modules must use domain role names such as run.ts, turn.ts, and model-ops.ts"
    },
    {
      "name": "gateway-run-start-contract-names",
      "pathPrefixes": ["gateway/src/extensions/contracts/run-start-"],
      "maxFiles": 0,
      "message": "start contract suites must use start-* names; run-start is a retired product-source prefix"
    }
  ],
  "sourceFileSizeWarnings": [
    {
      "name": "product-source",
      "includePrefixes": [
        "gateway/src/",
        "runtime/src/",
        "adapters/browser-structured-mcp/",
        "adapters/contextweaver/bridge/"
      ],
      "extensions": [".ts", ".tsx", ".mjs", ".js", ".rs"],
      "warn": 800,
      "fail": 1500,
      "maxWarnCount": 0,
      "maxFailCount": 0,
      "maxWarnOverflowLines": 0,
      "maxFailOverflowLines": 0,
      "maxObservedLines": 800
    },
    {
      "name": "gateway-test-source",
      "includePrefixes": ["gateway/tests/"],
      "extensions": [".ts", ".tsx", ".mjs", ".js"],
      "warn": 800,
      "fail": 1500,
      "maxWarnCount": 0,
      "maxFailCount": 0,
      "maxWarnOverflowLines": 0,
      "maxFailOverflowLines": 0,
      "maxObservedLines": 800
    }
  ],
  "forbiddenTextWarnings": [
    {
      "name": "cli-product-dev-cli-names",
      "includePrefixes": [
        "gateway/src/cli/",
        "gateway/src/orchestration/"
      ],
      "extensions": [".ts", ".tsx", ".mjs", ".js"],
      "patterns": [
        {
          "regex": "\\bDevCli\\b|\\brunDevCli\\b",
          "message": "Product CLI code must use Cli names; DevCli aliases are not part of the source architecture."
        },
        {
          "regex": "\\b[A-Za-z0-9_]*TsDevCli[A-Za-z0-9_]*\\b",
          "message": "Product CLI implementation names must use CLI or TypeScript runner naming; ts-dev-cli is reserved for runner/cache/compat labels."
        },
        {
          "regex": "\\b[A-Za-z0-9_]*ts_dev_cli[A-Za-z0-9_]*\\b",
          "message": "Product CLI implementation names must use CLI or TypeScript runner naming; ts-dev-cli is reserved for runner/cache/compat labels."
        },
        {
          "literal": "engine: \"ts-dev-cli\"",
          "message": "Product status/API engine identity must use gateway/src/cli/product-identity.ts."
        },
        {
          "literal": "engine: ts-dev-cli",
          "message": "Product status/API engine identity must use gateway/src/cli/product-identity.ts."
        },
        {
          "literal": "serve: ts-dev-cli",
          "message": "Product serve output must use gateway/src/cli/product-identity.ts."
        },
        {
          "literal": "unsupported command for ts-dev-cli",
          "message": "User-facing CLI errors must say grobot CLI, not ts-dev-cli."
        },
        {
          "literal": "ts-dev-cli fatal error",
          "message": "User-facing CLI fatal errors must say grobot CLI, not ts-dev-cli."
        },
        {
          "literal": "grobot-ts-dev-cli",
          "message": "Provider probe user-agent must use grobot-cli, not dev-cli."
        },
        {
          "literal": "rediss is not supported by ts-dev-cli",
          "message": "User-facing service errors must use product identity, not dev-cli."
        }
      ]
    }
  ],
  "importPolicyWarnings": [
    {
      "name": "runtime-model",
      "path": "runtime/src/models",
      "forbiddenCratePrefixes": ["extensions", "orchestration", "governance"]
    },
    {
      "name": "runtime-tools",
      "path": "runtime/src/tools",
      "forbiddenCratePrefixes": ["extensions", "orchestration", "governance"]
    },
    {
      "name": "runtime-extensions",
      "path": "runtime/src/extensions",
      "forbiddenCratePrefixes": ["governance"]
    },
    {
      "name": "runtime-orchestration",
      "path": "runtime/src/orchestration",
      "forbiddenCratePrefixes": ["extensions", "governance"]
    },
    {
      "name": "runtime-governance",
      "path": "runtime/src/governance",
      "forbiddenCratePrefixes": ["models", "tools", "extensions", "orchestration"]
    },
    {
      "name": "gateway-tools",
      "path": "gateway/src/tools",
      "fileExtensions": [".ts", ".tsx", ".mts", ".cts"],
      "forbiddenImportPrefixes": ["../extensions", "../orchestration", "../governance"]
    },
    {
      "name": "gateway-extensions",
      "path": "gateway/src/extensions",
      "fileExtensions": [".ts", ".tsx", ".mts", ".cts"],
      "forbiddenImportPrefixes": ["../governance"]
    }
  ],
  "importPolicyAllowlist": [
    {
      "pathEquals": "runtime/src/orchestration/tests.rs",
      "cratePrefix": "extensions"
    }
  ]
}
