#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  TARGET="$(readlink "$SOURCE")"
  if [[ "$TARGET" != /* ]]; then
    SOURCE="$SCRIPT_DIR/$TARGET"
  else
    SOURCE="$TARGET"
  fi
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
CLI_ENTRY="$SCRIPT_DIR/packages/cli/bin/grobot"
if [ -x "$CLI_ENTRY" ]; then
  exec "$CLI_ENTRY" "$@"
fi

# Source-checkout entry path.
TS_DEV_CLI_RUNNER="$SCRIPT_DIR/scripts/run-ts-dev-cli.sh"
FORWARD_ARGS=()
TS_DEV_FLAG_SEEN=0
PREV_ARG=""

is_truthy() {
  local value
  value="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"
  case "$value" in
    1|true|yes|on) return 0 ;;
    *) return 1 ;;
  esac
}

fail_legacy_python() {
  local detail="$1"
  echo "error: legacy python execution path is removed." >&2
  echo "detail: ${detail}" >&2
  echo "allowed: --gateway-impl ts, --runtime-impl rust" >&2
  return 2
}

for ARG in "$@"; do
  if [ -n "$PREV_ARG" ]; then
    if [ "$PREV_ARG" = "--gateway-impl" ] || [ "$PREV_ARG" = "--runtime-impl" ]; then
      VALUE_LOWER="$(printf '%s' "$ARG" | tr '[:upper:]' '[:lower:]')"
      if [ "$VALUE_LOWER" = "python" ]; then
        fail_legacy_python "${PREV_ARG}=${ARG}"
        exit 2
      fi
      FORWARD_ARGS+=("$ARG")
      PREV_ARG=""
      continue
    fi
    PREV_ARG=""
  fi
  case "$ARG" in
    --legacy-python-cli|--legacy-python-cli=*)
      fail_legacy_python "$ARG"
      exit 2
      ;;
    --ts-dev-cli|--ts-dev-cli=*)
      TS_DEV_FLAG_SEEN=1
      ;;
    --gateway-impl|--runtime-impl)
      PREV_ARG="$ARG"
      FORWARD_ARGS+=("$ARG")
      ;;
    --gateway-impl=python|--runtime-impl=python)
      fail_legacy_python "$ARG"
      exit 2
      ;;
    *)
      FORWARD_ARGS+=("$ARG")
      ;;
  esac
done

if is_truthy "${GROBOT_LEGACY_PYTHON:-}"; then
  fail_legacy_python "GROBOT_LEGACY_PYTHON=${GROBOT_LEGACY_PYTHON}"
  exit 2
fi

if [ "$TS_DEV_FLAG_SEEN" -eq 1 ]; then
  echo "warning: --ts-dev-cli is deprecated in source checkout and can be removed." >&2
fi

run_ts_dev_cli() {
  if [ ! -x "$TS_DEV_CLI_RUNNER" ]; then
    return 86
  fi
  if [ "${#FORWARD_ARGS[@]}" -gt 0 ]; then
    "$TS_DEV_CLI_RUNNER" "${FORWARD_ARGS[@]}"
  else
    "$TS_DEV_CLI_RUNNER"
  fi
}

set +e
run_ts_dev_cli
TS_DEV_CLI_EXIT_CODE=$?
set -e

if [ "$TS_DEV_CLI_EXIT_CODE" -eq 0 ]; then
  exit 0
fi

if [ "$TS_DEV_CLI_EXIT_CODE" -eq 86 ]; then
  echo "error: ts-dev-cli is unavailable in this source checkout." >&2
elif [ "$TS_DEV_CLI_EXIT_CODE" -eq 2 ] || [ "$TS_DEV_CLI_EXIT_CODE" -eq 3 ]; then
  echo "error: command is not available in ts-dev-cli." >&2
fi
exit "$TS_DEV_CLI_EXIT_CODE"
