{
  "name": "grobot",
  "private": false,
  "version": "0.1.0",
  "bin": {
    "grobot": "./grobot"
  },
  "files": [
    "grobot",
    "packages/cli/bin/grobot",
    "packages/templates/config.toml.example",
    "packages/templates/skills",
    "docs",
    "scripts/browser-setup.mjs",
    "adapters/contextweaver/bridge",
    "adapters/contextweaver/vendor/contextweaver/dist",
    "adapters/contextweaver/vendor/contextweaver/skills",
    "adapters/browser-structured-mcp",
    "gateway/src/extensions/contracts/browser-structured-mcp*.mjs",
    "shared/config/toml-config.mjs",
    "shared/retrieval/contextweaver-retrieval.mjs",
    "README.md"
  ],
  "scripts": {
    "pack:list": "npm pack --dry-run",
    "install:local": "bash ./scripts/install-local.sh",
    "install:local:strict-native": "bash ./scripts/install-local.sh --browser-native-setup-strict",
    "uninstall:local": "bash ./scripts/uninstall-local.sh",
    "core:install:binary": "bash ./scripts/install-core-binary.sh",
    "core:install:url": "bash ./scripts/install-core-from-url.sh",
    "core:status": "bash ./scripts/core-status.sh",
    "core:verify:packages": "bash ./scripts/core-verify-packages.sh",
    "core:manifest:generate": "bash ./scripts/core-generate-manifest.sh",
    "core:stage:artifacts": "bash ./scripts/core-stage-artifacts.sh",
    "core:gate:release": "bash ./scripts/core-release-gate.sh",
    "core:release:prepare": "bash ./scripts/core-release-prepare.sh",
    "core:release:bundles": "bash ./scripts/package-release-bundles.sh",
    "check": "node scripts/quality-runner.mjs run affected --compact",
    "check:affected": "node scripts/quality-runner.mjs run affected",
    "check:quick": "node scripts/quality-runner.mjs run quick",
    "check:prepush": "node scripts/quality-runner.mjs run prepush",
    "check:ci": "node scripts/quality-runner.mjs run ci",
    "check:release": "node scripts/quality-runner.mjs run release",
    "check:quality:plan": "node scripts/quality-runner.mjs plan affected",
    "check:quality:benchmark": "node scripts/quality-runner.mjs benchmark prepush",
    "check:quality:benchmark:guard": "node scripts/quality-runner.mjs benchmark prepush --samples 3 --changed-files scripts/checks/quality-runner/behavior.mjs,scripts/lib/quality-gate-registry.mjs --fail-on-median-ms 1000 --fail-on-p90-ms 12000 --fail-below-cache-hit-ratio 90",
    "check:quality:stats": "node scripts/quality-runner.mjs stats",
    "check:quality-runner": "node scripts/checks/quality-runner/behavior.mjs",
    "audit:python:target": "node scripts/python-scope-audit.mjs",
    "check:version": "node scripts/check-version-consistency.mjs",
    "sync:tools-all-reference": "node scripts/sync-tools-all-reference.mjs",
    "check:tools-all-reference": "node scripts/check-tools-all-reference.mjs",
    "check:layer-contract": "node scripts/layer-contract-check.mjs --strict",
    "check:layer-contract:strict": "node scripts/layer-contract-check.mjs --strict",
    "check:layer-contract:warn": "node scripts/layer-contract-check.mjs",
    "check:layer-contract:test": "node scripts/test-layer-contract-check.mjs",
    "check:gateway": "node gateway/tests/check-gateway-node.mjs",
    "check:gateway:json": "node gateway/tests/check-gateway-node.mjs --json",
    "check:gateway:strict": "node gateway/tests/check-gateway-node.mjs --fail-on-retry",
    "check:gateway:list-cases": "node gateway/tests/check-gateway-node.mjs --list-cases",
    "check:gateway:runtime-smoke": "node gateway/tests/check-gateway-node.mjs --runtime-smoke-only",
    "check:gateway:runtime-smoke:json": "node gateway/tests/check-gateway-node.mjs --runtime-smoke-only --json",
    "check:gateway:runtime-smoke:strict": "node gateway/tests/check-gateway-node.mjs --runtime-smoke-only --fail-on-retry",
    "check:gateway:runtime-smoke:baseline": "node gateway/tests/check-gateway-node.mjs --runtime-smoke-only --json-output /tmp/grobot-runtime-smoke-baseline.json",
    "check:gateway:runtime-smoke:report": "node gateway/tests/check-gateway-node.mjs --runtime-smoke-only --json-output /tmp/grobot-runtime-smoke-report.json",
    "check:gateway:runtime-smoke:diff": "node gateway/tests/check-gateway-node.mjs --runtime-smoke-only --json --baseline-json /tmp/grobot-runtime-smoke-baseline.json --json-output /tmp/grobot-runtime-smoke-report.json",
    "check:gateway:runtime-tools": "node scripts/check-runtime-tool-contracts.mjs && node scripts/test-runtime-tool-contracts-json-schema.mjs && node scripts/test-runtime-tool-quality-report-module.mjs && node scripts/test-runtime-tool-quality-registry-parity.mjs",
    "check:gateway:runtime-tools:json": "node scripts/check-runtime-tool-contracts.mjs --json",
    "check:gateway:runtime-tools:describe": "cargo build --manifest-path runtime/Cargo.toml && node scripts/check-runtime-tool-contracts.mjs --include-runtime-describe",
    "check:gateway:runtime-tools:release-report": "node scripts/test-runtime-tool-release-report.mjs",
    "check:gateway:runtime-tools:quality-report": "node scripts/test-runtime-tool-quality-report-module.mjs",
    "check:gateway:runtime-tools:quality-parity": "node scripts/test-runtime-tool-quality-registry-parity.mjs",
    "check:gateway:runtime-tools:schema": "node scripts/test-runtime-tool-contracts-json-schema.mjs",
    "check:browser-structured:mcp": "node gateway/src/extensions/contracts/browser-structured-mcp-contract.mjs && node gateway/src/extensions/contracts/browser-structured-mcp-hub-control-contract.mjs",
    "check:browser-doctor:schema": "node gateway/src/extensions/contracts/browser-doctor-json-schema-contract.mjs",
    "check:browser-structured:mcp:hub-control": "node gateway/src/extensions/contracts/browser-structured-mcp-hub-control-contract.mjs",
    "check:browser-structured:mcp:live": "node gateway/src/extensions/contracts/browser-structured-mcp-live-contract.mjs",
    "check:browser-structured:mcp:live:doctor": "node gateway/src/extensions/contracts/browser-structured-mcp-live-doctor.mjs",
    "check:browser-structured:mcp:live:gate": "node gateway/src/extensions/contracts/browser-structured-mcp-live-gate.mjs",
    "check:gateway:ts": "tsc --project gateway/tsconfig.json --noEmit",
    "check:runtime:check": "cargo check --manifest-path runtime/Cargo.toml",
    "check:runtime:test": "cargo test --manifest-path runtime/Cargo.toml",
    "check:runtime": "npm run check:runtime:check && npm run check:runtime:test",
    "harness:sample": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/runner.ts --cases gateway/evals/fixtures/cases.sample.jsonl --runs gateway/evals/fixtures/runs.sample.jsonl --gate-policy gateway/evals/gate_policy.default.json --output /tmp/grobot-harness-report.json",
    "harness:gate:sample": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/runner.ts --cases gateway/evals/fixtures/cases.sample.jsonl --runs gateway/evals/fixtures/runs.sample.jsonl --gate-policy gateway/evals/gate_policy.default.json --fail-on-gate",
    "harness:gate:ci": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/runner.ts --cases gateway/evals/fixtures/cases.ci.jsonl --runs gateway/evals/fixtures/runs.ci.jsonl --gate-policy gateway/evals/gate_policy.ci.json --fail-on-gate",
    "harness:context-memory:sample": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/context-memory-experience-eval.ts --cases gateway/evals/fixtures/context_memory_cases.sample.jsonl --runs gateway/evals/fixtures/context_memory_runs.sample.jsonl --gate-policy gateway/evals/context_memory_policy.sample.json --output /tmp/grobot-context-memory-report.json",
    "harness:context-memory:gate:sample": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/context-memory-experience-eval.ts --cases gateway/evals/fixtures/context_memory_cases.sample.jsonl --runs gateway/evals/fixtures/context_memory_runs.sample.jsonl --gate-policy gateway/evals/context_memory_policy.sample.json --fail-on-gate",
    "harness:context-memory:gate:ci": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/context-memory-experience-eval.ts --cases gateway/evals/fixtures/context_memory_cases.ci.jsonl --runs gateway/evals/fixtures/context_memory_runs.ci.jsonl --gate-policy gateway/evals/context_memory_policy.ci.json --output gateway/evals/data/context_memory_ci_report.json --fail-on-gate",
    "harness:context-memory:baseline": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/context-memory-baseline-report.ts",
    "harness:context-memory:ci-gate": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/context-memory-ci-gate.ts",
    "harness:trace-mine": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/trace-mining.ts --sessions-dir .grobot/sessions --cases-output gateway/evals/data/cases.trace.jsonl --runs-output gateway/evals/data/runs.trace_baseline.jsonl --variant trace_baseline",
    "harness:trace-clean": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/trace-clean.ts --cases-input gateway/evals/data/cases.trace.jsonl --runs-input gateway/evals/data/runs.trace_baseline.jsonl --cases-output gateway/evals/data/cases.trace.cleaned.jsonl --runs-output gateway/evals/data/runs.trace.cleaned.jsonl --report-output gateway/evals/data/trace_clean_report.json",
    "harness:trace-pipeline": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/trace-pipeline.ts",
    "harness:trace-pipeline:dev": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/trace-pipeline.ts --policy gateway/evals/trace_pipeline_policy.dev.json",
    "harness:trace-pipeline:ci": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/trace-pipeline.ts --policy gateway/evals/trace_pipeline_policy.ci.json",
    "harness:trace-pipeline:prod": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/trace-pipeline.ts --policy gateway/evals/trace_pipeline_policy.prod.json",
    "harness:trace-policy:check": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/trace-policy-guard.ts --policy gateway/evals/trace_pipeline_policy.dev.json --policy gateway/evals/trace_pipeline_policy.ci.json --policy gateway/evals/trace_pipeline_policy.prod.json",
    "harness:trace-policy:fingerprint": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/trace-policy-guard.ts --policy gateway/evals/trace_pipeline_policy.dev.json --policy gateway/evals/trace_pipeline_policy.ci.json --policy gateway/evals/trace_pipeline_policy.prod.json --print-json",
    "harness:trace-pipeline:validate": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/trace-pipeline.ts --policy gateway/evals/trace_pipeline_policy.ci.json --dry-validate-only --print-json",
    "harness:hill-climb:sample": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/hill-climb.ts --cases gateway/evals/fixtures/cases.sample.jsonl --runs gateway/evals/fixtures/runs.sample.jsonl --gate-policy gateway/evals/gate_policy.default.json --baseline-variant lexical --min-optimization-gain 0.0 --allow-holdout-drop 0.0",
    "harness:candidate:generate:sample": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/candidate-generator.ts --report /tmp/grobot-harness-report.json --output /tmp/grobot-candidate-proposals.json --max-proposals 4",
    "harness:loop:auto:sample": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/auto-loop.ts --cases gateway/evals/fixtures/cases.sample.jsonl --runs gateway/evals/fixtures/runs.sample.jsonl --gate-policy gateway/evals/gate_policy.default.json --baseline-variant lexical --output /tmp/grobot-auto-loop-report.json --manifest-output /tmp/grobot-candidate-proposals.json --ledger-path /tmp/grobot-experiment-ledger.jsonl --max-candidates 4 --max-rounds 2 --max-parallel 2 --consecutive-failures-to-stop 2 --cooldown-hours 12",
    "harness:loop:auto:ci": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/auto-loop.ts --cases gateway/evals/fixtures/cases.ci.jsonl --runs gateway/evals/fixtures/runs.ci.jsonl --gate-policy gateway/evals/gate_policy.ci.json --baseline-variant baseline --output gateway/evals/data/auto_loop_ci_report.json --manifest-output gateway/evals/data/candidate_proposals_ci.json --ledger-path gateway/evals/data/experiment_ledger_ci.jsonl --max-candidates 4 --max-rounds 2 --max-parallel 2 --consecutive-failures-to-stop 2 --cooldown-hours 12 --print-json",
    "harness:eval:retire-saturated:sample": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/eval-retire-saturated.ts --reports /tmp/grobot-harness-report.json --cases gateway/evals/fixtures/cases.sample.jsonl --output /tmp/grobot-saturated-cases.json --min-observations 2 --min-score 0.98 --max-retire-count 20 --print-json",
    "harness:ledger:tail": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/ledger-cli.ts --ledger-path /tmp/grobot-experiment-ledger.jsonl --tail 20",
    "harness:promotion:sample": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/promotion-protocol.ts --ledger-path /tmp/grobot-experiment-ledger.jsonl --proposal-id REPLACE_WITH_PROPOSAL_ID --action shadow-pass",
    "harness:skill-router:sample": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/skill-router-eval.ts --policy gateway/evals/skill_router_policy.dev.json --print-json",
    "harness:skill-router:baseline": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/skill-router-baseline-report.ts",
    "harness:skill-router:ci-gate": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/skill-router-ci-gate.ts",
    "harness:skill-router:gate:ci": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/skill-router-eval.ts --policy gateway/evals/skill_router_policy.ci.json --fail-on-gate",
    "harness:skill-router:gate:prod": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/skill-router-eval.ts --policy gateway/evals/skill_router_policy.prod.json --fail-on-gate",
    "harness:skill-router:policy:check": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/skill-router-policy-guard.ts --policy gateway/evals/skill_router_policy.dev.json --policy gateway/evals/skill_router_policy.ci.json --policy gateway/evals/skill_router_policy.prod.json",
    "harness:skill-router:policy:fingerprint": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/skill-router-policy-guard.ts --policy gateway/evals/skill_router_policy.dev.json --policy gateway/evals/skill_router_policy.ci.json --policy gateway/evals/skill_router_policy.prod.json --print-json",
    "harness:skill-router:policy:validate": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/skill-router-eval.ts --policy gateway/evals/skill_router_policy.dev.json --dry-validate-only --print-json && npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/skill-router-eval.ts --policy gateway/evals/skill_router_policy.ci.json --dry-validate-only --print-json && npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/skill-router-eval.ts --policy gateway/evals/skill_router_policy.prod.json --dry-validate-only --print-json",
    "harness:ci-label-policy:check": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/ci-label-policy-guard.ts --policy gateway/evals/ci_label_policy.json",
    "harness:ci-label-policy:fingerprint": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/ci-label-policy-guard.ts --policy gateway/evals/ci_label_policy.json --print-json",
    "harness:ci-summary": "npm run harness:ci-summary:build -- --trace-report gateway/evals/data/trace_pipeline_ci_report.json --skill-router-report gateway/evals/data/skill_router_ci_report.json --context-memory-report gateway/evals/data/context_memory_ci_report.json --weekly-regression-report gateway/evals/data/weekly_regression_ci_report.json --print-json",
    "harness:ci-summary:build": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/ci-summary.ts",
    "harness:ci-summary:export": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/ci-summary-export.ts",
    "harness:weekly-regression:ci-gate": "npx --yes --package tsx@4.20.6 tsx gateway/src/governance/evals/weekly-regression-ci-gate.ts",
    "browser:tmwd:hub": "node adapters/browser-structured-mcp/tmwd-hub.mjs",
    "browser:tmwd:hub:start": "node adapters/browser-structured-mcp/tmwd-hub-control.mjs start",
    "browser:tmwd:hub:stop": "node adapters/browser-structured-mcp/tmwd-hub-control.mjs stop",
    "browser:tmwd:hub:status": "node adapters/browser-structured-mcp/tmwd-hub-control.mjs status",
    "browser:setup": "node scripts/browser-setup.mjs",
    "browser:native:doctor": "node adapters/browser-structured-mcp/native-deps-setup.mjs",
    "browser:native:setup": "node adapters/browser-structured-mcp/native-deps-setup.mjs --install --yes",
    "browser:native:setup:json": "node adapters/browser-structured-mcp/native-deps-setup.mjs --install --yes --json"
  },
  "dependencies": {
    "@types/react": "19.2.14",
    "ink": "7.0.1",
    "react": "19.2.5",
    "toml": "^3.0.0",
    "ws": "8.18.0"
  },
  "devDependencies": {
    "tsx": "4.20.6",
    "typescript": "5.6.3"
  }
}
